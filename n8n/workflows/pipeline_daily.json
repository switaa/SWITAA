{
  "name": "Marcus - Daily Pipeline (Discover + Score)",
  "nodes": [
    {
      "parameters": {"rule": {"interval": [{"triggerAtHour": 3, "triggerAtMinute": 15}]}},
      "name": "Cron 3h15",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "url": "http://backend:8000/api/v1/discover/run",
        "method": "POST",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "marketplace", "value": "amazon_fr"},
            {"name": "source", "value": "keepa"}
          ]
        },
        "options": {"timeout": 300000}
      },
      "name": "Discover",
      "type": "n8n-nodes-base.httpRequest",
      "position": [500, 300]
    },
    {
      "parameters": {"value": 30, "unit": "seconds"},
      "name": "Wait 30s",
      "type": "n8n-nodes-base.wait",
      "position": [750, 300]
    }
  ],
  "connections": {
    "Cron 3h15": {"main": [[{"node": "Discover", "type": "main", "index": 0}]]},
    "Discover": {"main": [[{"node": "Wait 30s", "type": "main", "index": 0}]]}
  }
}
